# Copia questo file in .env.local e riempi con i valori del tuo progetto Firebase
# (Firebase Console > Impostazioni progetto > Generale > Le tue app > Configurazione SDK)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
